#!/usr/bin/env python3
"""codex-issue — the fix fleet's issue-workflow tool (CodeAxis contract v2).

Runs on the fleet machine (NOT on the CodeAxis server). The fleet prompt's
prose state machine (locking, reopen safety, skip rules, dependency rescan,
completion protocol) lives HERE as code; the prompt just calls subcommands
and obeys their exit codes. CodeAxis's issue tracker parses the structured
comment `finish` posts (<!-- codex-report/v1 {...} -->) to close the
feedback loop (progress tracking, hit rate, retrieval eval ground truth).

Subcommands:
  claim <iid> [--dry-run]   atomic claim: skip checks + reopen precheck +
                            lock branch creation. Exit 0=claimed,
                            2=skip (reason on stdout), 1=real blocker.
  release <iid>             drop this issue's lock branch (idempotent).
  block <iid> --by <iid> [--reason ...]
                            mark dependency-blocked: label
                            codex:blocked-by-<n> + audit comment + release.
  merge-lock / merge-unlock acquire/release the global test merge lock
                            (codex-lock/merge-test). Exit 2 = busy.
  rescan                    dependency-unblock sweep over open issues:
                            removes codex:blocked-by-* whose prerequisites
                            are all satisfied, comments the release.
  finish <iid> --commit <sha> [--files f1,f2,...]
                            idempotent completion: verify sha reachable
                            from TARGET_BRANCH → find-or-post
                            codex-report/v1 comment → ensure label → close.

Config (env file, default ~/.codex/xinchuan-digital.env, or env vars;
override path with CODEX_ISSUE_ENV):
  GITLAB_URL      https://<host>/<group>/<project>   (project web URL)
  GITLAB_TOKEN    API token
  TARGET_BRANCH   default: test
  CODEX_WORKER_ID recommended: export once per worker session
"""

import argparse
import json
import os
import re
import sys
import time
import urllib.parse
import urllib.request


def die(msg: str, code: int = 1):
    print(f"codex-issue: {msg}", file=sys.stderr)
    sys.exit(code)


def load_config() -> dict:
    env_file = os.environ.get("CODEX_ISSUE_ENV", os.path.expanduser("~/.codex/xinchuan-digital.env"))
    cfg = {}
    if os.path.exists(env_file):
        with open(env_file) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    cfg[k.strip()] = v.strip().strip('"').strip("'")
    for key in ("GITLAB_URL", "GITLAB_TOKEN", "TARGET_BRANCH"):
        if os.environ.get(key):
            cfg[key] = os.environ[key]
    if not cfg.get("GITLAB_URL") or not cfg.get("GITLAB_TOKEN"):
        die(f"GITLAB_URL / GITLAB_TOKEN not configured (checked {env_file} and env vars)")
    cfg.setdefault("TARGET_BRANCH", "test")
    return cfg


def api(cfg: dict, method: str, path: str, params: dict | None = None, body: dict | None = None):
    parsed = urllib.parse.urlparse(cfg["GITLAB_URL"])
    project = urllib.parse.quote(parsed.path.strip("/"), safe="")
    url = f"{parsed.scheme}://{parsed.netloc}/api/v4/projects/{project}{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params)
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method, headers={
        "PRIVATE-TOKEN": cfg["GITLAB_TOKEN"],
        **({"Content-Type": "application/json"} if data else {}),
    })
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return resp.status, json.loads(resp.read().decode() or "null")
    except urllib.error.HTTPError as e:
        return e.code, json.loads(e.read().decode() or "null")


def worker_id() -> str:
    return os.environ.get("CODEX_WORKER_ID") or f"codex-{time.strftime('%Y%m%d%H%M%S')}-{os.getpid()}"


REPORT_RE = re.compile(r"<!--\s*codex-report/v1\s*(\{.*?\})\s*-->", re.DOTALL)
LEGACY_DONE_RE = re.compile(r"已合并并推送到\s*origin/test")
SKIP = 2  # exit code: not an error — this issue just isn't claimable now


def skip(msg: str):
    print(f"SKIP: {msg}")
    sys.exit(SKIP)


def get_branch_head(cfg, branch: str) -> str:
    status, data = api(cfg, "GET", f"/repository/branches/{urllib.parse.quote(branch, safe='')}")
    if status != 200:
        die(f"GitLab API {status} reading branch {branch}")
    return data["commit"]["id"]


def create_lock(cfg, name: str, ref_sha: str) -> str:
    """Create-only lock via the branches API. Returns 'acquired' | 'busy';
    anything else dies (401/403/network = real blocker, per fleet protocol)."""
    status, data = api(cfg, "POST", "/repository/branches",
                       params={"branch": name, "ref": ref_sha})
    if status == 201:
        return "acquired"
    text = json.dumps(data, ensure_ascii=False)
    if status in (400, 409) and ("exists" in text or "已存在" in text):
        return "busy"
    die(f"GitLab API {status} creating lock {name}: {text[:200]}")


def delete_lock(cfg, name: str):
    status, _ = api(cfg, "DELETE", f"/repository/branches/{urllib.parse.quote(name, safe='')}")
    if status in (204, 404):  # gone either way — idempotent
        return
    die(f"GitLab API {status} deleting lock {name}")


def iter_notes(cfg, iid: int):
    for page in range(1, 6):
        status, notes = api(cfg, "GET", f"/issues/{iid}/notes",
                            params={"per_page": 100, "page": page, "sort": "asc"})
        if status != 200:
            die(f"GitLab API {status} listing notes")
        yield from notes
        if len(notes) < 100:
            return


def completion_signal_time(cfg, iid: int) -> str | None:
    """Latest completion evidence: a codex-report/v1 (or legacy-format)
    comment, or the last add of the codex:merged-to-test label."""
    latest = None
    for note in iter_notes(cfg, iid):
        body = note.get("body") or ""
        if REPORT_RE.search(body) or LEGACY_DONE_RE.search(body):
            t = note.get("created_at")
            if t and (latest is None or t > latest):
                latest = t
    status, events = api(cfg, "GET", f"/issues/{iid}/resource_label_events",
                         params={"per_page": 100})
    if status == 200:
        for ev in events:
            if ev.get("action") == "add" and (ev.get("label") or {}).get("name") == "codex:merged-to-test":
                t = ev.get("created_at")
                if t and (latest is None or t > latest):
                    latest = t
    return latest


def reopen_precheck(cfg, iid: int) -> tuple[str, str]:
    """For an open issue carrying completion evidence: is that evidence still
    valid? Returns (verdict, reason) — verdict 'skip' (valid, just never got
    closed: do NOT claim, do NOT close) or 'claimable' (invalidated by a
    reopen or later human comment: needs a real re-fix)."""
    done_at = completion_signal_time(cfg, iid)
    if not done_at:
        return "claimable", "有 merged-to-test 迹象但找不到完成记录，按普通候选处理"
    status, events = api(cfg, "GET", f"/issues/{iid}/resource_state_events",
                         params={"per_page": 100})
    if status != 200:
        return "skip", f"无法读取状态事件（API {status}），不能安全判断，跳过"
    for ev in events:
        if ev.get("state") == "reopened" and (ev.get("created_at") or "") > done_at:
            return "claimable", f"完成记录({done_at})之后发生 reopen，旧完成标记已失效"
    for note in iter_notes(cfg, iid):
        body = note.get("body") or ""
        if (not note.get("system") and (note.get("created_at") or "") > done_at
                and not REPORT_RE.search(body) and not LEGACY_DONE_RE.search(body)):
            return "claimable", f"完成记录之后出现新的人工评论（note {note['id']}），需重新确认"
    return "skip", f"完成记录({done_at})仍有效，仅历史未关闭 — 不领取、不关闭"


def prerequisite_satisfied(cfg, pre_iid: int) -> bool:
    status, pre = api(cfg, "GET", f"/issues/{pre_iid}")
    if status != 200:
        return False  # can't confirm → not satisfied
    return pre.get("state") == "closed" or "codex:merged-to-test" in (pre.get("labels") or [])


def cmd_claim(args, cfg):
    iid = args.issue_iid
    status, issue = api(cfg, "GET", f"/issues/{iid}")
    if status == 404:
        skip(f"issue #{iid} 不存在")
    if status != 200:
        die(f"GitLab API {status} reading issue")
    if issue.get("state") == "closed":
        skip("issue 已关闭")
    labels = issue.get("labels") or []

    if "codex:in-progress" in labels:
        skip("codex:in-progress — 其他 worker 处理中")
    if any(l in labels for l in ("codex:waiting-merge", "codex:ready-for-review")):
        skip("历史遗留/人工介入状态（waiting-merge / ready-for-review）")
    blocked_by = [l for l in labels if l.startswith("codex:blocked-by-")]
    for l in blocked_by:
        try:
            pre_iid = int(l.rsplit("-", 1)[1])
        except ValueError:
            skip(f"无法解析依赖标签 {l}，需人工处理")
        if not prerequisite_satisfied(cfg, pre_iid):
            skip(f"前置 #{pre_iid} 尚未合入（{l}）")
    if any(l in ("blocked", "status:blocked", "codex:blocked") for l in labels) and not blocked_by:
        skip("通用 blocked 标记（无可回扫的 blocked-by-*），不自动处理")

    if "codex:merged-to-test" in labels or completion_signal_time(cfg, iid):
        verdict, reason = reopen_precheck(cfg, iid)
        if verdict == "skip":
            skip(reason)
        print(f"预检: {reason}")

    if args.dry_run:
        print(f"DRY-RUN: issue #{iid} 可领取（未创建锁）— {issue.get('title', '')[:60]}")
        return

    ref = get_branch_head(cfg, cfg["TARGET_BRANCH"])
    result = create_lock(cfg, f"codex-lock/issue-{iid}", ref)
    if result == "busy":
        skip("锁已存在 — 其他 worker 已领取")
    print(f"CLAIMED: issue #{iid} — {issue.get('title', '')}")
    print(f"lock: codex-lock/issue-{iid} @ {ref[:10]}  worker: {worker_id()}")
    if "codex:merged-to-test" in labels:
        api(cfg, "PUT", f"/issues/{iid}", body={"remove_labels": "codex:merged-to-test"})
        print("已移除失效的 codex:merged-to-test")


def cmd_release(args, cfg):
    delete_lock(cfg, f"codex-lock/issue-{args.issue_iid}")
    print(f"released: codex-lock/issue-{args.issue_iid}")


def cmd_block(args, cfg):
    iid, pre = args.issue_iid, args.by
    label = f"codex:blocked-by-{pre}"
    status, _ = api(cfg, "PUT", f"/issues/{iid}", body={"add_labels": label})
    label_note = "" if status == 200 else f"（label 写入失败 API {status}，以本评论为准）"
    body = (f"🔒 依赖阻塞：#{iid} 依赖 #{pre}，前置未合入 origin/test，暂不处理。{label_note}\n"
            f"worker: {worker_id()}  time: {time.strftime('%Y-%m-%dT%H:%M:%S%z')}\n"
            f"原因: {args.reason or '前置依赖未完成'}")
    api(cfg, "POST", f"/issues/{iid}/notes", body={"body": body})
    delete_lock(cfg, f"codex-lock/issue-{iid}")
    print(f"blocked-by #{pre} 已登记，锁已释放")


def cmd_merge_lock(args, cfg):
    ref = get_branch_head(cfg, cfg["TARGET_BRANCH"])
    if create_lock(cfg, "codex-lock/merge-test", ref) == "busy":
        print("BUSY: 其他 worker 正在合并 test，等待后重试")
        sys.exit(SKIP)
    print(f"merge lock acquired @ {ref[:10]}")


def cmd_merge_unlock(args, cfg):
    delete_lock(cfg, "codex-lock/merge-test")
    print("merge lock released")


def cmd_rescan(args, cfg):
    unblocked = 0
    for page in range(1, 11):
        status, issues = api(cfg, "GET", "/issues",
                             params={"state": "opened", "per_page": 100, "page": page})
        if status != 200:
            die(f"GitLab API {status} listing open issues")
        for issue in issues:
            labels = issue.get("labels") or []
            blocked_by = [l for l in labels if l.startswith("codex:blocked-by-")]
            if not blocked_by:
                continue
            pres = []
            for l in blocked_by:
                try:
                    pres.append(int(l.rsplit("-", 1)[1]))
                except ValueError:
                    pres = None
                    break
            if pres is None or not all(prerequisite_satisfied(cfg, p) for p in pres):
                continue
            iid = issue["iid"]
            api(cfg, "PUT", f"/issues/{iid}", body={"remove_labels": ",".join(blocked_by)})
            api(cfg, "POST", f"/issues/{iid}/notes", body={
                "body": f"🔓 前置依赖（{', '.join('#' + str(p) for p in pres)}）已合入 origin/test，"
                        f"解除依赖阻塞，可重新领取。worker: {worker_id()}"})
            print(f"unblocked: #{iid}（前置 {pres} 已满足）")
            unblocked += 1
        if len(issues) < 100:
            break
    print(f"rescan complete: {unblocked} 个 issue 解除阻塞")


def cmd_finish(args, cfg):
    iid, sha = args.issue_iid, args.commit

    # 1. commit must already be on the target branch — hard gate
    status, refs = api(cfg, "GET", f"/repository/commits/{urllib.parse.quote(sha, safe='')}/refs",
                       params={"type": "branch", "per_page": 100})
    if status == 404:
        die(f"commit {sha} not found on the remote — push first")
    if status != 200:
        die(f"GitLab API {status} checking commit refs")
    branches = {b.get("name") for b in refs}
    if cfg["TARGET_BRANCH"] not in branches:
        die(f"commit {sha} is NOT reachable from '{cfg['TARGET_BRANCH']}' "
            f"(found on: {', '.join(sorted(branches)) or 'no branches'}) — merge before finishing")

    # 2. files list: explicit, or derived from the commit diff
    if args.files:
        files = [f.strip() for f in args.files.split(",") if f.strip()]
    else:
        status, diff = api(cfg, "GET", f"/repository/commits/{urllib.parse.quote(sha, safe='')}/diff",
                           params={"per_page": 100})
        if status != 200:
            die(f"GitLab API {status} fetching commit diff for files list")
        files = sorted({d.get("new_path") or d.get("old_path") for d in diff if d})

    # 3. find-or-create the structured report comment (idempotent by sha)
    existing = None
    for page in range(1, 6):
        status, notes = api(cfg, "GET", f"/issues/{iid}/notes", params={"per_page": 100, "page": page})
        if status != 200:
            die(f"GitLab API {status} listing notes")
        for note in notes:
            m = REPORT_RE.search(note.get("body") or "")
            if m:
                try:
                    if json.loads(m.group(1)).get("commit_sha") == sha:
                        existing = note
                except json.JSONDecodeError:
                    pass
        if len(notes) < 100:
            break
    if existing:
        print(f"report comment already present (note {existing['id']}) — skipping post")
    else:
        payload = {"worker_id": worker_id(), "commit_sha": sha, "files": files, "verified": True}
        body_text = (f"✅ 修复完成并已合入 {cfg['TARGET_BRANCH']}（commit {sha[:10]}，"
                     f"{len(files)} 个文件）\n\n<!-- codex-report/v1 {json.dumps(payload, ensure_ascii=False)} -->")
        status, note = api(cfg, "POST", f"/issues/{iid}/notes", body={"body": body_text})
        if status != 201:
            die(f"GitLab API {status} posting report comment: {note}")
        print(f"posted report comment (note {note['id']})")

    # 4. ensure label, then close (each idempotent; close failure is non-fatal)
    status, issue = api(cfg, "GET", f"/issues/{iid}")
    if status != 200:
        die(f"GitLab API {status} fetching issue")
    labels = issue.get("labels") or []
    if "codex:merged-to-test" not in labels:
        api(cfg, "PUT", f"/issues/{iid}", body={"add_labels": "codex:merged-to-test"})
        print("label codex:merged-to-test added")
    if issue.get("state") != "closed":
        status, _ = api(cfg, "PUT", f"/issues/{iid}", body={"state_event": "close"})
        print("issue closed" if status == 200 else
              f"WARNING: close failed (API {status}) — report+label are in place, safe to re-run")
    else:
        print("issue already closed")
    print(f"finish complete: issue #{iid} / commit {sha[:10]}")


def main():
    parser = argparse.ArgumentParser(prog="codex-issue")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_claim = sub.add_parser("claim", help="atomically claim an issue (skip checks + reopen precheck + lock)")
    p_claim.add_argument("issue_iid", type=int)
    p_claim.add_argument("--dry-run", action="store_true", help="run all checks, don't create the lock")

    p_release = sub.add_parser("release", help="drop this issue's lock branch (idempotent)")
    p_release.add_argument("issue_iid", type=int)

    p_block = sub.add_parser("block", help="record a dependency block and release the lock")
    p_block.add_argument("issue_iid", type=int)
    p_block.add_argument("--by", type=int, required=True, help="prerequisite issue iid")
    p_block.add_argument("--reason")

    sub.add_parser("merge-lock", help="acquire the global test merge lock (exit 2 = busy)")
    sub.add_parser("merge-unlock", help="release the global test merge lock")
    sub.add_parser("rescan", help="dependency-unblock sweep over open issues")

    p_finish = sub.add_parser("finish", help="report a merged fix and close the issue (idempotent)")
    p_finish.add_argument("issue_iid", type=int)
    p_finish.add_argument("--commit", required=True, help="fix commit sha (must already be on TARGET_BRANCH)")
    p_finish.add_argument("--files", help="comma-separated changed files; default: derived from the commit diff")

    args = parser.parse_args()
    cfg = load_config()
    {
        "claim": cmd_claim, "release": cmd_release, "block": cmd_block,
        "merge-lock": cmd_merge_lock, "merge-unlock": cmd_merge_unlock,
        "rescan": cmd_rescan, "finish": cmd_finish,
    }[args.cmd](args, cfg)


if __name__ == "__main__":
    main()
