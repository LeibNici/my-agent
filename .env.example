ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096
# ⚠️ Do NOT set ANTHROPIC_SYSTEM_PROMPT unless you deliberately want to REPLACE
# the carefully-tuned read-only assistant prompt built into app/config.py
# (it enforces "confirm bugs, never rewrite files, draft one issue per problem").
# Setting any value here overrides that entire prompt.
# ANTHROPIC_SYSTEM_PROMPT=
# Max tool-use round trips per chat turn before the agent gives up with an error.
# Raise this if complex multi-file investigations hit "Reached max tool iterations".
ANTHROPIC_MAX_TOOL_ITERATIONS=30

# How often (minutes) all repos are auto-synced in the background. 0 disables it —
# repos will still sync on startup and whenever an admin creates/edits/manually syncs one.
APP_REPO_SYNC_INTERVAL_MINUTES=10

# Comma-separated origins allowed to call the API cross-origin. Update this
# when deploying somewhere other than localhost:8000.
APP_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Semantic code search (embeddings) ---
# Powers the semantic_search tool: business-language queries (中文可用) matched
# against code by meaning. Defaults target DashScope's OpenAI-compatible
# endpoint; when APP_EMBEDDING_API_KEY is left empty the ANTHROPIC_API_KEY is
# reused (they're the same account on a DashScope deployment). The index is a
# sidecar file next to each repo checkout (<local_path>.emb.npz), rebuilt
# incrementally after every sync — a no-change sync costs zero API calls.
# APP_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# APP_EMBEDDING_API_KEY=
# APP_EMBEDDING_MODEL=text-embedding-v4
# APP_EMBEDDING_DIMENSIONS=1024
