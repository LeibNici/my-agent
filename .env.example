ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_SYSTEM_PROMPT=You are a helpful AI assistant with access to various tools.
# Max tool-use round trips per chat turn before the agent gives up with an error.
# Raise this if complex multi-file investigations hit "Reached max tool iterations".
ANTHROPIC_MAX_TOOL_ITERATIONS=30

# How often (minutes) all repos are auto-synced in the background. 0 disables it —
# repos will still sync on startup and whenever an admin creates/edits/manually syncs one.
APP_REPO_SYNC_INTERVAL_MINUTES=10

# Comma-separated origins allowed to call the API cross-origin. Update this
# when deploying somewhere other than localhost:8000.
APP_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
